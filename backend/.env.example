# Copy to .env and adjust. Defaults work for local dev with SQLite (no Docker needed).
DJANGO_SECRET_KEY=dev-insecure-change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,10.0.2.2

# Leave DB_ENGINE=sqlite for the simplest local start.
# Set DB_ENGINE=postgres (and the values below) to use the docker-compose Postgres.
DB_ENGINE=sqlite
POSTGRES_DB=smartkineto
POSTGRES_USER=smartkineto
POSTGRES_PASSWORD=smartkineto
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

REDIS_URL=redis://127.0.0.1:6379/0
